# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.0-pro

# Google Maps Platform
GOOGLE_MAPS_API_KEY=your-maps-api-key

# Server
PORT=8080

# Auth for Vertex AI SDK (ADC)
# On Windows, set GOOGLE_APPLICATION_CREDENTIALS to the absolute path of serviceAccountKey.json
# Example:
# GOOGLE_APPLICATION_CREDENTIALS=E:\\thom\\cargomind\\backend\\serviceAccountKey.json
